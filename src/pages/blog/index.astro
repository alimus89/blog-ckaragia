---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1060px, calc(100% - 2em));
			}
			.intro {
				max-width: 65ch;
				margin: 0 auto 1.4rem;
				padding: 1.1rem 1.25rem;
				border-radius: 14px;
				background: rgba(255, 255, 255, 0.74);
				border: 1px solid rgba(18, 206, 199, 0.2);
			}
			.intro h1 {
				margin: 0 0 0.2rem;
				font-size: clamp(1.7rem, 1.4rem + 1.4vw, 2.5rem);
			}
			.intro p {
				margin: 0;
			}
			ul {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 1.2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: 100%;
			}
			ul li * {
				text-decoration: none;
				transition: 0.25s ease;
			}
			ul li:first-child {
				grid-column: 1 / -1;
			}
			ul li:first-child img {
				width: 100%;
				height: auto;
			}
			ul li:first-child .title {
				font-size: clamp(1.75rem, 1.35rem + 1.5vw, 2.3rem);
			}
			ul li img {
				margin-bottom: 0.65rem;
				border-radius: 14px;
				aspect-ratio: 2 / 1;
				object-fit: cover;
			}
			ul li a {
				display: block;
				padding: 1rem;
				border-radius: 16px;
				background: rgba(255, 255, 255, 0.8);
				border: 1px solid rgba(18, 206, 199, 0.18);
				box-shadow: 0 8px 16px rgba(17, 34, 66, 0.08);
			}
			.title {
				margin: 0;
				color: rgb(var(--black));
				line-height: 1.15;
			}
			.date {
				margin: 0.4rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: var(--accent-dark);
			}
			ul a:hover img {
				box-shadow: var(--box-shadow);
			}
			ul li a:hover {
				transform: translateY(-2px);
				border-color: rgba(15, 97, 191, 0.35);
			}
			@media (max-width: 720px) {
				ul {
					grid-template-columns: 1fr;
					gap: 0.7em;
				}
				ul li {
					width: 100%;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="intro">
					<h1>Blog</h1>
					<p>Thoughts, lessons learned, and practical notes from ongoing projects.</p>
				</div>
				<ul>
					{
						posts.map((post, index) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<img
										width={720}
										height={360}
										src={post.data.heroImage}
										alt=""
										loading={index === 0 ? 'eager' : 'lazy'}
										decoding="async"
										fetchpriority={index === 0 ? 'high' : 'auto'}
									/>
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
