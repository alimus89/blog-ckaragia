---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Personal Journal</p>
				<h1>ckaragia</h1>
				<p class="lead">
					Notes on building useful products, writing better code, and staying curious while shipping.
				</p>
				<div class="actions">
					<a href="/blog" class="button primary">Read the Blog</a>
					<a href="/about" class="button secondary">About Me</a>
				</div>
			</section>

			<section class="highlights" aria-label="Site highlights">
				<article class="highlight-card">
					<h2>Fresh Articles</h2>
					<p>Short, practical posts focused on engineering craft, process, and product thinking.</p>
				</article>
				<article class="highlight-card">
					<h2>Clear Writing</h2>
					<p>Every post aims to be concise, structured, and useful enough to revisit later.</p>
				</article>
				<article class="highlight-card">
					<h2>Continuous Updates</h2>
					<p>Content evolves over time with learnings from shipped projects and experiments.</p>
				</article>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 2.2rem;
		border-radius: 22px;
		background:
			radial-gradient(circle at 8% 15%, rgba(18, 206, 199, 0.34), rgba(18, 206, 199, 0)),
			radial-gradient(circle at 94% 10%, rgba(44, 87, 207, 0.3), rgba(44, 87, 207, 0)),
			rgba(255, 255, 255, 0.82);
		box-shadow: var(--box-shadow);
	}
	.eyebrow {
		margin: 0;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: var(--accent-dark);
		font-weight: 700;
	}
	h1 {
		margin-top: 0.45rem;
		margin-bottom: 0.75rem;
	}
	.lead {
		max-width: 38ch;
		margin: 0;
	}
	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		margin-top: 1.4rem;
	}
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1rem;
		font-size: 0.95rem;
		font-weight: 700;
		border-radius: 999px;
		text-decoration: none;
		border: 1px solid transparent;
	}
	.button.primary {
		background: linear-gradient(120deg, var(--accent), var(--accent-alt));
		color: white;
	}
	.button.secondary {
		color: var(--accent-dark);
		border-color: rgba(15, 97, 191, 0.35);
		background: rgba(255, 255, 255, 0.85);
	}
	.highlights {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}
	.highlight-card {
		padding: 1.2rem;
		border-radius: 16px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(18, 206, 199, 0.2);
		box-shadow: 0 8px 18px rgba(17, 34, 66, 0.08);
	}
	.highlight-card h2 {
		font-size: 1.2rem;
		margin-bottom: 0.4rem;
	}
	.highlight-card p {
		margin: 0;
		font-size: 0.95rem;
	}
	@media (max-width: 900px) {
		.highlights {
			grid-template-columns: 1fr;
		}
	}
	@media (max-width: 720px) {
		.hero {
			padding: 1.5rem;
		}
		.button {
			width: 100%;
		}
	}
</style>
